# ==================== Database Configuration ====================
# SQLiteファイルのパス（開発環境）
DATABASE_URL=sqlite:///./studyapp.db

# ==================== Backend API Configuration ====================
# APIバインドするホスト（開発: 127.0.0.1=localhost のみ、本番: 環境変数で上書き）
API_HOST=127.0.0.1

# APIポート
API_PORT=8080

# ホットリロード（開発のみ true に設定）
RELOAD=true
RELOAD_DIRS=app;frontend
RELOAD_EXCLUDES=.venv/*;.git/*;*.db;*.sqlite;*.sqlite3;data/*.csv

# 起動時にブラウザを自動で開くか
AUTO_OPEN_BROWSER=true

# CORS許可するオリジン（開発: localhost:3000 のみ、本番: 環境変数で上書き）
CORS_ORIGINS=http://localhost:3000

# ==================== Frontend Server Configuration ====================
# フロントエンドサーバーのポート
FRONTEND_SERVER_PORT=3000

# フロントエンド のAPIエンドポイント
FRONTEND_API_BASE_URL=http://localhost:8080
